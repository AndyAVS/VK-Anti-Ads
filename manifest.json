{
  "manifest_version": 3,
  "name": "VK Anti-Ads ",
  "version": "0.0.3",
  "description": "Очищает ленту ВК от рекламных постов",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "js": ["scripts/content-script.js"],
      "matches": ["https://vk.com/*"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon32.png"
  },
  "homepage_url": "https://github.com/AndyAVS/VK-Anti-Ads"
}